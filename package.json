{
  "name": "padterm",
  "version": "0.1.0",
  "description": "AI-First iPad Developer Terminal",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "node --loader tsx server/index.ts",
    "build": "next build",
    "build:backend": "tsc server/index.ts --outDir dist",
    "start": "next start",
    "start:backend": "node dist/server/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "express": "^4.18.2",
    "ws": "^8.14.0",
    "ssh2": "^1.14.0",
    "@octokit/rest": "^20.0.0",
    "@octokit/auth-oauth-device": "^6.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "tailwindcss": "^3.3.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.20",
    "@types/ws": "^8.5.8",
    "@types/ssh2": "^1.11.13",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.1.0",
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.30"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
